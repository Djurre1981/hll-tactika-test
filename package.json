{
  "name": "hll-tactika",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/run-dev.mjs",
    "dev:vite": "vite",
    "dev:api": "wrangler pages dev . --port 8788 --compatibility-date=2024-01-01",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "node scripts/deploy-pages.mjs",
    "db:migrate:local": "wrangler d1 migrations apply hll-tactika-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply hll-tactika-db --remote",
    "db:migrate:preview": "wrangler d1 migrations apply hll-tactika-db --remote --preview",
    "db:migrate-kv": "node scripts/kv-to-d1/migrate.mjs --remote",
    "db:migrate-kv:dry": "node scripts/kv-to-d1/migrate.mjs --dry-run --remote",
    "db:migrate-strats": "node scripts/kv-to-d1/migrate-strats.mjs --remote",
    "db:migrate-strats:local": "node scripts/kv-to-d1/migrate-strats.mjs --local",
    "db:migrate-strats:dry": "node scripts/kv-to-d1/migrate-strats.mjs --dry-run --remote",
    "migrate:videos:setup": "powershell -File scripts/video-migration/setup-r2.ps1",
    "migrate:videos:export": "node scripts/video-migration/1-export-discord.mjs",
    "migrate:videos:download": "node scripts/video-migration/2-download-videos.mjs",
    "migrate:videos:upload": "node scripts/video-migration/3-upload-r2.mjs",
    "migrate:videos:apply": "node scripts/video-migration/4-apply-kv.mjs",
    "stratsketch:spike": "node scripts/stratsketch-spike.mjs",
    "stratsketch:icons": "node scripts/build-stratsketch-icon-pack.mjs",
    "vectorize:hll-objects": "node scripts/vectorize-hll-objects.mjs",
    "extract:accessibility": "node scripts/extract-accessibility.mjs && node scripts/trace-accessibility-mono.mjs",
    "extract:accessibility:vectors": "node scripts/trace-accessibility-vectors.mjs",
    "extract:accessibility:mono": "node scripts/trace-accessibility-mono.mjs",
    "merge:vector-obstacles": "node scripts/merge-vector-obstacles.mjs",
    "import:obstacle-svg": "node scripts/import-obstacle-svg.mjs",
    "trace:mono-overlay-vectors": "node scripts/trace-mono-overlay-vectors.mjs",
    "extract:hq-spawns": "node scripts/extract-hq-spawns.mjs",
    "extract:vehicles": "node scripts/extract-vehicles.mjs",
    "test": "node --test tests/**/*.test.mjs",
    "test:t1": "node --test tests/t1-event-hub.test.mjs tests/migrations.test.mjs",
    "test:t2": "node --test tests/t2-match-details.test.mjs tests/t2-api-sanitize.test.mjs tests/calendar-utils.test.mjs tests/migrations.test.mjs",
    "import:helo": "node scripts/import-helo-history.mjs",
    "import:helo:pilot": "node scripts/import-helo-history.mjs --only Circle-PF-2026-07-12",
    "import:helo:jr": "node scripts/import-helo-history.mjs --team jr",
    "import:helo:jr:apply-local": "node scripts/import-helo-history.mjs --team jr --apply --local-d1",
    "import:helo:apply-local": "node scripts/import-helo-history.mjs --apply --local-d1",
    "backfill:helo-participants": "node scripts/backfill-helo-participants.mjs",
    "backfill:helo-participants:local": "node scripts/backfill-helo-participants.mjs --apply --local-d1",
    "backfill:helo-player-stats": "node scripts/backfill-helo-player-stats.mjs",
    "backfill:helo-player-stats:local": "node scripts/backfill-helo-player-stats.mjs --apply --local-d1",
    "backfill:match-team": "node scripts/backfill-match-team.mjs",
    "seed:roster:helo": "node scripts/seed-roster-from-helo-events.mjs"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.4",
    "imagetracerjs": "^1.2.6",
    "postcss": "^8.5.19",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.19",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0",
    "ws": "^8.21.0"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@tanstack/react-query": "^5.101.2",
    "lib0": "^0.2.117",
    "polygon-clipping": "^0.15.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "recharts": "^2.15.4",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.31",
    "zustand": "^5.0.14"
  }
}
