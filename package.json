{
  "name": "hll-tactika",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/run-dev.mjs",
    "dev:vite": "vite",
    "dev:api": "wrangler pages dev . --port 8788 --compatibility-date=2024-01-01",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler pages deploy dist --project-name=hll-tactika --branch=main",
    "db:migrate:local": "wrangler d1 migrations apply hll-tactika-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply hll-tactika-db --remote",
    "db:migrate:preview": "wrangler d1 migrations apply hll-tactika-db --remote --preview",
    "db:migrate-kv": "node scripts/kv-to-d1/migrate.mjs --remote",
    "db:migrate-kv:dry": "node scripts/kv-to-d1/migrate.mjs --dry-run --remote",
    "db:migrate-strats": "node scripts/kv-to-d1/migrate-strats.mjs --remote",
    "db:migrate-strats:local": "node scripts/kv-to-d1/migrate-strats.mjs --local",
    "db:migrate-strats:dry": "node scripts/kv-to-d1/migrate-strats.mjs --dry-run --remote",
    "migrate:videos:setup": "powershell -File scripts/video-migration/setup-r2.ps1",
    "migrate:videos:export": "node scripts/video-migration/1-export-discord.mjs",
    "migrate:videos:download": "node scripts/video-migration/2-download-videos.mjs",
    "migrate:videos:upload": "node scripts/video-migration/3-upload-r2.mjs",
    "migrate:videos:apply": "node scripts/video-migration/4-apply-kv.mjs",
    "stratsketch:spike": "node scripts/stratsketch-spike.mjs",
    "stratsketch:icons": "node scripts/build-stratsketch-icon-pack.mjs",
    "gen:mpa-html": "node scripts/gen-mpa-html.mjs"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.4",
    "postcss": "^8.5.19",
    "tailwindcss": "^3.4.19",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0",
    "ws": "^8.21.0"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "zustand": "^5.0.14"
  }
}
