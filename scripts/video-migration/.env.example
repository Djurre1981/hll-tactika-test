# Copy to .env in this folder (never commit .env).
# Requires: npx wrangler login (for apply-kv step)

# Discord bot with Read Message History + Message Content Intent, access to #climbing-guide
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Cloudflare R2 S3 API credentials (Dashboard → R2 → Manage R2 API Tokens)
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=hll-climb-videos

# KV namespace id for production pins (from wrangler.toml PINS_KV id)
PINS_KV_NAMESPACE_ID=f526ba31599a4425ab30b42ac226820e
