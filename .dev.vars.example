# Required
SESSION_SECRET=some-long-random-session-secret-here
PIN_DETAIL_SECRET=a-different-long-random-pin-detail-secret

# Role allowlists (comma-separated SteamIDs if several)
OWNER_STEAM_IDS=76561198062852642
ADMIN_STEAM_IDS=76561198062852642
ASSIST_STEAM_IDS=
EDITOR_STEAM_IDS=
VIEWER_STEAM_IDS=

# Legacy alias for VIEWER_STEAM_IDS (optional; can leave empty if you use VIEWER_STEAM_IDS)
USER_STEAM_IDS=

# Optional
# STEAM_API_KEY=your-steam-web-api-key
# Admin alert-test only (browse traffic no longer posts Discord abuse alerts)
ALERT_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...,https://discord.com/api/webhooks/...

