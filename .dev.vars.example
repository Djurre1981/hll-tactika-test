USER_STEAM_IDS=

# Optional
# STEAM_API_KEY=your-steam-web-api-key
# Admin alert-test only (browse traffic no longer posts Discord abuse alerts)
ALERT_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...,https://discord.com/api/webhooks/...

# Phase 8 – Live collaboration (must match Render + Cloudflare Pages)
COLLAB_JWT_SECRET=replace-with-long-random-shared-secret
COLLAB_PERSIST_SECRET=replace-with-different-long-random-secret
# Local: ws://localhost:4080  |  Production: wss://hll-tactika-test.onrender.com
COLLAB_WS_URL=ws://localhost:4080
