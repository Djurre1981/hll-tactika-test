# Copy to .dev.vars for local `npm run dev` (never commit .dev.vars).
SESSION_SECRET=replace-with-a-long-random-string
PIN_DETAIL_SECRET=replace-with-another-long-random-string
OWNER_STEAM_IDS=76561198000000000
ADMIN_STEAM_IDS=76561198000000000
ASSIST_STEAM_IDS=
EDITOR_STEAM_IDS=
VIEWER_STEAM_IDS=
# Legacy alias for VIEWER_STEAM_IDS (Comp Member):
USER_STEAM_IDS=
# Legacy fallback: if ADMIN_STEAM_IDS is empty, ALLOWED_STEAM_IDS is treated as admins.
# ALLOWED_STEAM_IDS=
# Optional: Steam Web API key (https://steamcommunity.com/dev/apikey). Falls back to public profile XML if omitted.
# STEAM_API_KEY=
